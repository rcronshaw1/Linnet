---
interface Props {
  item: Record<string, unknown>;
}
const { item } = Astro.props;
const title = (item.title ?? item.name ?? item.query ?? 'Item') as string;
const url = (item.url ?? item.link ?? item.html_url) as string | undefined;
const summary = (item.summary ?? item.requirements ?? item.abstract ?? item.description) as string | undefined;
const truncated = summary && summary.length > 300 ? summary.slice(0, 300) + '…' : summary;
---
<article class="generic-card panel panel--strong">
  <h3 class="generic-card__title">
    {url ? (
      <a href={url} target="_blank" rel="noopener">{title}</a>
    ) : title}
  </h3>
  {truncated && <p class="generic-card__body">{truncated}</p>}
</article>

<style>
.generic-card {
  padding: 1rem 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.generic-card__title {
  font-size: 0.97rem;
  font-weight: 700;
  line-height: 1.4;
  color: var(--site-text);
}

.generic-card__title a { color: inherit; text-decoration: none; }
.generic-card__title a:hover { color: var(--site-brand); }

.generic-card__body {
  font-size: 0.86rem;
  color: var(--site-text-muted);
  line-height: 1.65;
}
</style>
