---
import { getExtensionsForLocale } from '@/lib/registry';
import WizardStep1 from './WizardStep1.astro';
import WizardStep2 from './WizardStep2.astro';
import WizardStep3 from './WizardStep3.astro';
import WizardStep4 from './WizardStep4.astro';
import WizardStep6 from './WizardStep6.astro';

interface Props {
  locale: 'en' | 'zh';
}
const { locale } = Astro.props;

const extensions = getExtensionsForLocale(locale);
const setupBridgeUrl = import.meta.env.PUBLIC_SETUP_BRIDGE_URL || 'https://linnet-setup-bridge.yuyangxueed.workers.dev';

const STEPS = locale === 'zh'
  ? ['简报', '细节', '密钥', '高级', '部署']
  : ['Brief', 'Details', 'Secrets', 'Advanced', 'Deploy'];

const STEP_BLURBS = locale === 'zh'
  ? [
      '先选一个 briefing 模式，再决定是否要展开高级来源选择。',
      '只对当前启用的来源做细调，arXiv 的详细参数也统一放在这里。',
      '这里只填写你真正启用过的额外 secrets 和推送渠道；没有用到的内容可以先跳过。',
      '先填好必需的 LLM access，再视情况调整全局默认值、weekly/monthly 和主题。',
      '最后检查目标仓库、自动启用选项和后续动作，然后把配置写入 GitHub。',
    ]
  : [
      'Pick a briefing mode first, then decide whether you want to open the advanced source picker.',
      'Tune only the sources you actually enabled, with all arXiv detail living in one place.',
      'Only fill the extra secrets and delivery channels you actually enabled, and skip the rest.',
      'Set the required LLM access first, then refine global defaults, weekly/monthly rollups, and theme if you want.',
      'Confirm the target repository, auto-enable options, and next actions before writing everything to GitHub.',
    ];

const backLabel = locale === 'zh' ? '上一步' : 'Back';
const nextLabel = locale === 'zh' ? '下一步' : 'Next';
const connectTitle = locale === 'zh' ? '部署方式' : 'Deploy Path';
const connectDesc = locale === 'zh'
  ? '先决定最后是手动提交配置，还是通过 Linnet Bridge 完成更低门槛的一键部署。'
  : 'Choose whether you want to finish with manual config handoff or use Linnet Bridge for the lower-friction one-click path.';
const connectModeTitle = locale === 'zh' ? 'Connect GitHub 一键部署' : 'One-click with Connect GitHub';
const connectModeMeta = locale === 'zh' ? '安装 App + 浏览器授权' : 'Install app + browser auth';
const connectModeDesc = locale === 'zh'
  ? '推荐给第一次上手的用户。先安装 Linnet Bridge GitHub App，再授权当前浏览器；到第 5 步时可以直接写入仓库、secrets、Pages 和 Actions 配置。'
  : 'Recommended for first-time users. Install the Linnet Bridge GitHub App first, then authorize this browser; at Step 5 Linnet can write files, secrets, Pages, and Actions setup for you.';
const manualModeTitle = locale === 'zh' ? 'Advanced manual config' : 'Advanced manual config';
const manualModeMeta = locale === 'zh' ? '复制 YAML + 手动加 secrets' : 'Copy YAML + add secrets';
const manualModeDesc = locale === 'zh'
  ? '继续使用生成的 YAML 和 secret 清单，手动提交到自己的仓库。'
  : 'Export YAML blocks and the secret checklist, then commit everything yourself.';
const installButtonLabel = locale === 'zh' ? '安装 GitHub App' : 'Install GitHub App';
const connectButtonLabel = locale === 'zh' ? '授权 GitHub' : 'Authorize GitHub';
const disconnectButtonLabel = locale === 'zh' ? '断开连接' : 'Disconnect';
const bridgeHint = locale === 'zh'
  ? '这条路径不再要求新人手动创建 PAT。流程是：先安装 App 到目标仓库，再回到这里授权当前浏览器。'
  : 'This path no longer asks new users to mint a PAT. The flow is: install the app on the target repository first, then return here and authorize this browser.';
const connectStatusIdle = locale === 'zh'
  ? '还没有 GitHub 连接。请先安装 Linnet Bridge GitHub App，然后授权当前浏览器。'
  : 'GitHub is not connected yet. Install the Linnet Bridge GitHub App first, then authorize this browser.';
const connectSummaryIdle = locale === 'zh'
  ? '未连接时，你仍然可以完成向导并导出配置，但需要自己提交文件和 secrets。完成安装后，GitHub 会把你带回这个 setup 页面。'
  : 'You can still complete the wizard without connecting, but you will commit files and secrets yourself. After installation, GitHub will bring you back to this setup page.';
---

<div
  class="wz"
  data-locale={locale}
  data-wizard
  data-setup-bridge-url={setupBridgeUrl}
  data-step-blurbs={JSON.stringify(STEP_BLURBS)}
>

  <section class="wz-entry">
    <div class="wz-entry__bar">
      <div class="wz-entry__copy">
        <div class="wz-entry__eyebrow">{connectTitle}</div>
        <p class="wz-entry__desc">{connectDesc}</p>
      </div>
      <div class="wz-entry__modes">
        <button
          type="button"
          class="wz-entry-chip"
          data-setup-mode-btn="connect"
          aria-pressed="true"
        >
          <span class="wz-entry-chip__title">{connectModeTitle}</span>
          <span class="wz-entry-chip__meta">{connectModeMeta}</span>
        </button>
        <button
          type="button"
          class="wz-entry-chip"
          data-setup-mode-btn="manual"
          aria-pressed="false"
        >
          <span class="wz-entry-chip__title">{manualModeTitle}</span>
          <span class="wz-entry-chip__meta">{manualModeMeta}</span>
        </button>
      </div>
    </div>
    <div class="wz-card" data-setup-mode-panel="connect" hidden={false}>
      <h3>{connectModeTitle}</h3>
      <p class="wz-card__desc">{connectModeDesc}</p>
      <div class="wz-auth-actions">
        <button type="button" class="wz-btn wz-btn--secondary" data-github-install-btn>
          {installButtonLabel}
        </button>
        <button type="button" class="wz-btn wz-btn--primary" data-github-connect-btn>
          {connectButtonLabel}
        </button>
        <button type="button" class="wz-btn wz-btn--ghost" data-github-disconnect-btn hidden>
          {disconnectButtonLabel}
        </button>
      </div>
      <div class="wz-field__hint" style="margin-top:12px">
        {bridgeHint}
      </div>
      <div class="wz-notice wz-notice--info" data-github-auth-status>
        {connectStatusIdle}
      </div>
      <div class="wz-auth-summary" data-github-auth-summary>{connectSummaryIdle}</div>
    </div>

    <div class="wz-card" data-setup-mode-panel="manual" hidden={true}>
      <h3>{manualModeTitle}</h3>
      <p class="wz-card__desc">{manualModeDesc}</p>
      <div class="wz-notice wz-notice--info">
        <strong>{locale === 'zh' ? '适合这些情况' : 'Best for'}</strong>
        <div>
          {locale === 'zh'
            ? '你希望继续保持 fork-and-run，不把任何 GitHub 授权状态保留在浏览器里。'
            : 'You want to keep the original fork-and-run model and avoid keeping GitHub auth state in the browser.'}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Progress bar ────────────────────────────────────────── -->
  <nav class="wz-progress" data-progress-anchor aria-label={locale === 'zh' ? '向导进度' : 'Wizard progress'}>
    <div class="wz-progress__bar">
      <div class="wz-progress__fill" data-progress-fill style="width:0%"></div>
    </div>
    <div class="wz-progress__steps">
      {STEPS.map((label, i) => (
        <button
          type="button"
          class="wz-progress__step"
          data-step-btn={i + 1}
          aria-current={i === 0 ? 'step' : 'false'}
        >
          <span class="wz-progress__num">{i + 1}</span>
          <span class="wz-progress__label">{label}</span>
        </button>
      ))}
    </div>
  </nav>

  <!-- ── Step header ─────────────────────────────────────────── -->
  <div class="wz-step-header">
    <div class="wz-step-header__pill" data-step-pill>
      {locale === 'zh' ? '第 1 步 / 共 5 步' : 'Step 1 of 5'}
    </div>
    <p class="wz-step-header__blurb" data-step-blurb>{STEP_BLURBS[0]}</p>
  </div>

  <!-- ── Step panels ─────────────────────────────────────────── -->
  <div class="wz-panels">
    <WizardStep1 {extensions} {locale} />
    <WizardStep2 {extensions} {locale} />
    <WizardStep3 {locale} />
    <WizardStep4 {extensions} {locale} />
    <WizardStep6 {locale} />
  </div>

  <!-- ── Navigation ─────────────────────────────────────────── -->
  <div class="wz-nav">
    <button type="button" class="wz-btn wz-btn--ghost" data-wizard-back disabled>
      {backLabel}
    </button>
    <button type="button" class="wz-btn wz-btn--primary" data-wizard-next>
      {nextLabel}
    </button>
  </div>

</div>

<script>
  import { initWizard } from './wizardController';
  initWizard();
</script>

<style is:global>
/* ── Shell ──────────────────────────────────────────────────── */
.wz {
  font-family: var(--font-body);
  color: var(--ink);
  max-width: 1200px;
  margin: 0 auto;
}

.wz-entry {
  margin-bottom: 48px;
  padding: 32px;
  background: var(--bg-deep);
  border: 1px solid var(--rule);
}

.wz-entry__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
  margin-bottom: 12px;
}

.wz-entry__desc {
  margin: 0;
  color: var(--ink-soft);
  line-height: 1.7;
  font-size: 0.875rem;
  max-width: 50ch;
}

.wz-entry__bar {
  display: flex;
  justify-content: space-between;
  gap: 32px;
  align-items: flex-start;
  margin-bottom: 24px;
}

.wz-entry__copy {
  flex: 1;
}

.wz-entry__modes {
  display: flex;
  gap: 8px;
  background: var(--bg);
  padding: 4px;
  border: 1px solid var(--rule);
}

.wz-entry-chip {
  min-width: 240px;
  padding: 14px 18px;
  border: none;
  background: transparent;
  cursor: pointer;
  transition: all 0.2s ease;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.wz-entry-chip__title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink);
  line-height: 1.15;
}

.wz-entry-chip__meta {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

.wz-entry-chip[aria-pressed="true"] {
  background: var(--paper);
  color: var(--ink);
  box-shadow: var(--shadow);
}

.wz-entry__hint {
  margin-top: -8px;
  margin-bottom: 24px;
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.08em;
  color: var(--ink-muted);
  line-height: 1.7;
}

.wz-auth-actions {
  display: flex;
  gap: 12px;
  align-items: center;
  margin: 16px 0;
}

.wz-auth-summary {
  color: var(--ink-soft);
  line-height: 1.65;
}

.wz-user-badge {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: var(--bg);
  border: 1px solid var(--rule);
  margin-bottom: 8px;
}

.wz-user-badge__avatar {
  width: 48px;
  height: 48px;
  border-radius: 4px;
  border: 1px solid var(--rule);
}

.wz-user-badge__info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.wz-user-badge__name {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.2;
}

.wz-user-badge__meta {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  color: var(--ink-muted);
  letter-spacing: 0.02em;
}

/* ── Progress bar ──────────────────────────────────────────── */
.wz-progress {
  margin-bottom: 48px;
}

.wz-progress__bar {
  height: 1px;
  background: var(--rule);
  margin-bottom: 24px;
  position: relative;
}

.wz-progress__fill {
  position: absolute;
  inset: 0 auto 0 0;
  background: var(--accent);
  height: 2px;
  top: -0.5px;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.wz-progress__steps {
  display: flex;
  justify-content: space-between;
  gap: 0;
}

.wz-progress__step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  flex: 1;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-muted);
  transition: all 0.3s ease;
  position: relative;
}

.wz-progress__step[aria-current="step"] { color: var(--accent); }
.wz-progress__step[data-complete="true"] { color: var(--ink); }

.wz-progress__num {
  font-family: var(--font-display);
  font-size: 0.875rem;
  font-weight: 700;
  width: 28px;
  height: 28px;
  border: 1px solid var(--rule);
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: var(--paper);
  transition: all 0.3s ease;
  z-index: 2;
}

.wz-progress__step[aria-current="step"] .wz-progress__num {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg);
  transform: scale(1.1);
  box-shadow: 0 0 0 4px var(--accent-soft);
}

.wz-progress__step[data-complete="true"] .wz-progress__num {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--bg);
}

.wz-progress__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 700;
}

/* ── Step header ───────────────────────────────────────────── */
.wz-step-header {
  margin-bottom: 40px;
  text-align: center;
}

.wz-step-header__pill {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
  margin-bottom: 12px;
}

.wz-step-header__blurb {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.25rem;
  color: var(--ink-soft);
  line-height: 1.5;
  max-width: 32ch;
  margin: 0 auto;
}

/* ── Step panels ───────────────────────────────────────────── */
.wz-panels { position: relative; }

.wz-step { display: none; }
.wz-step[aria-hidden="false"] { display: block; }

/* ── Navigation ────────────────────────────────────────────── */
.wz-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24px;
  margin-top: 24px;
  border-top: 1px solid var(--rule);
}

/* ── Buttons ────────────────────────────────────────────────── */
.wz-btn {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  padding: 10px 28px;
  border: 1px solid var(--ink);
  cursor: pointer;
  transition: all 0.2s ease;
  text-decoration: none;
  font-weight: 700;
}

.wz-btn--primary {
  background: var(--ink);
  color: var(--bg);
}
.wz-btn--primary:hover {
  background: var(--accent);
  border-color: var(--accent);
  transform: translateY(-1px);
}
.wz-btn--ghost { background: transparent; color: var(--ink); }
.wz-btn--ghost:hover {
  background: var(--bg-deep);
}
.wz-btn:disabled { opacity: 0.25; cursor: not-allowed; }

/* ── Cards ──────────────────────────────────────────────────── */
.wz-card {
  border: 1px solid var(--rule);
  padding: 32px;
  background: var(--paper);
  margin-bottom: 24px;
}

.wz-card h3 {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin: 0 0 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--rule-soft);
}

.wz-card__desc {
  font-size: 0.875rem;
  color: var(--ink-soft);
  line-height: 1.65;
  margin: 0 0 18px;
  max-width: none;
}

.wz-card__header {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  align-items: start;
}

.wz-card__header h3 {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.wz-card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20px;
  align-items: start;
}

.wz-card--span-2 {
  grid-column: 1 / -1;
}

.wz-card--compact {
  padding: 24px;
}

.wz-card--compact h3 {
  margin-bottom: 12px;
  padding-bottom: 10px;
}

.wz-card--compact .wz-card__desc {
  margin-bottom: 14px;
}

.wz-brief-card {
  margin-bottom: 32px;
}

.wz-brief-mode-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 20px;
}

.wz-brief-mode-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 18px;
  border: 1px solid var(--rule);
  background: var(--bg);
  cursor: pointer;
  text-align: left;
  transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
}

.wz-brief-mode-card:hover {
  border-color: var(--ink-soft);
}

.wz-brief-mode-card[aria-pressed="true"] {
  border-color: var(--accent);
  background: var(--paper);
  box-shadow: var(--shadow);
  transform: translateY(-1px);
}

.wz-brief-mode-card__title {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.15;
}

.wz-brief-mode-card__meta {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
}

.wz-brief-mode-card__desc {
  font-family: var(--font-body);
  color: var(--ink-soft);
  line-height: 1.65;
  font-size: 0.875rem;
  margin-top: 2px;
  flex: 1;
  text-wrap: pretty;
}

.wz-brief-mode-panel {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--rule);
}

.wz-brief-selection-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  min-height: 24px;
  margin-top: 12px;
}

.wz-brief-advanced {
  border: 1px solid var(--rule);
  padding: 24px 28px 28px;
  background: var(--paper);
}

.wz-brief-advanced__summary {
  display: flex;
  flex-direction: column;
  gap: 6px;
  cursor: pointer;
  list-style: none;
}

.wz-brief-advanced__summary::-webkit-details-marker {
  display: none;
}

.wz-brief-advanced__title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ink);
}

.wz-brief-advanced__desc {
  font-size: 0.875rem;
  color: var(--ink-soft);
  line-height: 1.6;
  max-width: 58ch;
}

.wz-brief-advanced[open] .wz-brief-advanced__title {
  color: var(--accent);
}

.wz-brief-advanced .wz-step1-layout {
  margin-top: 20px;
}

.wz-advanced-card {
  border: 1px solid var(--rule);
  padding: 24px 28px 28px;
  background: var(--paper);
}

.wz-advanced-card--block {
  margin-top: 24px;
}

.wz-advanced-card__summary {
  display: flex;
  flex-direction: column;
  gap: 6px;
  cursor: pointer;
  list-style: none;
}

.wz-advanced-card__summary::-webkit-details-marker {
  display: none;
}

.wz-advanced-card__title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--ink);
}

.wz-advanced-card__desc {
  font-size: 0.875rem;
  color: var(--ink-soft);
  line-height: 1.6;
  max-width: 60ch;
}

.wz-advanced-card[open] .wz-advanced-card__title {
  color: var(--accent);
}

.wz-advanced-card__content {
  margin-top: 20px;
}

/* ── Stack ──────────────────────────────────────────────────── */
.wz-stack { display: flex; flex-direction: column; gap: 24px; }

.wz-field-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}

/* ── Slider ─────────────────────────────────────────────────── */
.wz-slider-row {
  display: flex;
  align-items: center;
  gap: 16px;
  min-height: 46px;
  padding: 10px 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
}

.wz-slider-row input[type="range"] {
  flex: 1;
  accent-color: var(--accent);
}

.wz-slider-val {
  font-family: var(--font-mono);
  font-size: 0.875rem;
  min-width: 2.5ch;
  text-align: right;
  color: var(--ink);
  font-weight: 700;
}

/* ── Multi-select chips ─────────────────────────────────────── */
.wz-multiselect {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
}

.wz-chip-label { cursor: pointer; }
.wz-chip-label input[type="checkbox"] { display: none; }

.wz-chip {
  display: inline-flex;
  flex-direction: column;
  gap: 2px;
  padding: 8px 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.08em;
  font-weight: 700;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  color: var(--ink-muted);
}

.wz-chip__sub {
  font-size: 0.63rem;
  color: var(--ink-muted);
  font-family: var(--font-body);
  letter-spacing: 0;
  text-transform: none;
  font-weight: 400;
}

.wz-chip-label input:checked + .wz-chip {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg);
}

.wz-chip-label input:checked + .wz-chip .wz-chip__sub { color: rgba(255,255,255,0.7); }

/* ── Tags / URLs input ──────────────────────────────────────── */
.wz-tags, .wz-urls {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
}

.wz-tags__list, .wz-urls__list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  min-height: 32px;
}

.wz-tags__empty, .wz-urls__empty {
  font-size: 0.875rem;
  color: var(--ink-muted);
  font-style: italic;
}

.wz-tags__input-row, .wz-urls__input-row {
  display: flex;
  gap: 10px;
}

.wz-tags__input, .wz-urls__input {
  flex: 1;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  min-height: 42px;
  padding: 8px 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink);
  outline: none;
}

.wz-tags__add, .wz-urls__add {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  min-height: 42px;
  padding: 8px 16px;
  border: 1px solid var(--ink);
  background: transparent;
  color: var(--ink);
  font-weight: 700;
  cursor: pointer;
}

.wz-tags__add:hover, .wz-urls__add:hover {
  background: var(--ink);
  color: var(--bg);
}

.wz-tag, .wz-url-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 4px 10px;
  border: 1px solid var(--rule);
  background: var(--bg-deep);
  font-family: var(--font-mono);
  font-size: 0.69rem;
  color: var(--ink-soft);
  font-weight: 600;
}

.wz-tag__remove, .wz-url-item__remove {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-muted);
  font-size: 1rem;
  padding: 0;
  line-height: 1;
}

.wz-tag__remove:hover, .wz-url-item__remove:hover { color: var(--accent); }

.wz-field-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}

.wz-field-row .wz-field { min-width: 0; }

.wz-field-stack { display: flex; flex-direction: column; gap: 20px; }
.wz-field { display: flex; flex-direction: column; gap: 8px; }

.wz-field--rich {
  padding: 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
}

.wz-field label,
.wz-field__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

.wz-field input[type="text"],
.wz-field input[type="password"],
.wz-field input[type="number"],
.wz-field input[type="url"],
.wz-field select {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  width: 100%;
  min-height: 46px;
  padding: 10px 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink);
  outline: none;
  transition: all 0.2s ease;
}

.wz-field input:focus,
.wz-field select:focus {
  border-color: var(--ink);
  background: var(--paper);
  box-shadow: 0 0 0 3px var(--accent-soft);
}

.wz-field__hint {
  font-size: 0.8125rem;
  color: var(--ink-muted);
  line-height: 1.6;
  font-style: italic;
}

.wz-field__meta {
  font-size: 0.76rem;
  color: var(--ink-muted);
  line-height: 1.55;
}

.wz-field__meta code {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  color: var(--ink);
}

.wz-field__meta a {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.wz-required-marker {
  color: var(--accent);
  margin-left: 0.3ch;
  font-size: 0.95em;
}

.wz-switch {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  padding: 14px 16px;
  border: 1px solid var(--rule);
  background: var(--bg);
  cursor: pointer;
}

.wz-switch input[type="checkbox"] {
  margin: 2px 0 0;
  inline-size: 18px;
  block-size: 18px;
  accent-color: var(--accent);
  flex: 0 0 auto;
}

.wz-switch > span {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* ── arXiv profile grid ─────────────────────────────────────── */
.wz-profile-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
  margin-top: 12px;
}

.wz-profile-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
  cursor: pointer;
  transition: all 0.2s ease;
}

.wz-profile-card input { display: none; }

.wz-profile-card:hover { border-color: var(--ink-soft); }

.wz-profile-card:has(input:checked) {
  border-color: var(--accent);
  background: var(--accent-soft);
  box-shadow: 0 2px 12px rgba(0,0,0,0.05);
}

.wz-profile-card__name {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--ink);
}

.wz-profile-card__summary {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--ink-muted);
  line-height: 1.5;
}

/* ── Toggle ─────────────────────────────────────────────────── */
.wz-toggle {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
}

.wz-toggle input[type="checkbox"] {
  width: 40px; height: 22px;
  appearance: none;
  background: var(--rule);
  border-radius: 20px;
  cursor: pointer;
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}

.wz-toggle input[type="checkbox"]::after {
  content: '';
  position: absolute;
  top: 3px; left: 3px;
  width: 16px; height: 16px;
  background: var(--paper);
  border-radius: 50%;
  transition: left 0.2s;
}

.wz-toggle input[type="checkbox"]:checked {
  background: var(--accent);
}

.wz-toggle input[type="checkbox"]:checked::after { left: 21px; }

.wz-toggle__label {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

/* ── Notices ────────────────────────────────────────────────── */
.wz-notice {
  padding: 16px 20px;
  border: 1px solid var(--rule);
  border-left: 4px solid var(--rule);
  font-family: var(--font-body);
  font-size: 0.9375rem;
  line-height: 1.7;
  color: var(--ink-soft);
  margin-bottom: 24px;
}

.wz-notice strong {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--ink);
  display: block;
  margin-bottom: 6px;
}
.wz-notice--info  { border-left-color: var(--accent); background: var(--paper); }
.wz-notice--warn  { border-left-color: var(--gold); background: var(--paper); }
.wz-notice--success { border-left-color: var(--sage); background: var(--paper); }

.wz-checklist {
  margin: 8px 0 0;
  padding-left: 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.wz-result-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.wz-result-item {
  padding: 14px 16px;
  border: 1px solid var(--rule);
  background: var(--bg);
}

.wz-result-item--span-2 {
  grid-column: 1 / -1;
}

.wz-result-item__label {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

.wz-result-item__value {
  margin-top: 8px;
  font-family: var(--font-display);
  font-size: 1.05rem;
  line-height: 1.2;
  color: var(--ink);
}

.wz-result-item__hint {
  margin-top: 6px;
  font-size: 0.8125rem;
  line-height: 1.55;
  color: var(--ink-soft);
}

.wz-result-links {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.wz-result-links a {
  color: var(--accent);
}

/* ── Step 1 layout ──────────────────────────────────────────── */
.wz-step1-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 48px;
  align-items: start;
}

.wz-search {
  width: 100%;
  font-family: var(--font-body);
  font-size: 1rem;
  padding: 12px 0;
  border: none;
  border-bottom: 2px solid var(--rule);
  background: transparent;
  color: var(--ink);
  margin-bottom: 24px;
  outline: none;
  transition: border-color 0.2s;
}
.wz-search:focus { border-color: var(--accent); }

.wz-filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 32px;
}

.wz-filter-chips .wz-chip {
  background: var(--bg-deep);
  border: 1px solid var(--rule);
  color: var(--ink-muted);
  padding: 6px 14px;
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.wz-filter-chips .wz-chip--active,
.wz-filter-chips .wz-chip[aria-pressed="true"] {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg);
}

.wz-ext-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 20px;
  max-height: 600px;
  overflow-y: auto;
  padding-right: 12px;
}

/* Scrollbar styling for editorial feel */
.wz-ext-grid::-webkit-scrollbar { width: 4px; }
.wz-ext-grid::-webkit-scrollbar-track { background: var(--rule-soft); }
.wz-ext-grid::-webkit-scrollbar-thumb { background: var(--rule); }

.wz-ext-card {
  position: relative;
  padding: 24px;
  border: 1px solid var(--rule);
  background: var(--paper);
  text-align: left;
  cursor: pointer;
  transition: all 0.2s ease;
  min-height: 180px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.wz-ext-card:hover {
  border-color: var(--ink);
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.wz-ext-card[aria-pressed="true"] {
  border-color: var(--accent);
  background: var(--accent-soft);
}

.wz-ext-card__check {
  position: absolute;
  top: 16px; right: 16px;
  font-size: 0.75rem;
  color: var(--bg);
  background: var(--accent);
  width: 22px; height: 22px;
  border-radius: 50%;
  display: grid; place-items: center;
  opacity: 0;
  transform: scale(0.5);
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.wz-ext-card[aria-pressed="true"] .wz-ext-card__check {
  opacity: 1;
  transform: scale(1);
}

.wz-ext-card__name {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink);
  line-height: 1.2;
}

.wz-ext-card__desc {
  font-family: var(--font-body);
  font-size: 0.875rem;
  color: var(--ink-soft);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}

.wz-ext-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: auto;
}

.wz-label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  padding: 2px 8px;
  background: var(--bg-deep);
  color: var(--ink-muted);
  border: none;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.wz-label--ghost {
  background: transparent;
  border: 1px solid var(--rule);
}

/* ── Step 2 configure sheet ─────────────────────────────────── */
.wz-step2-sheet {
  background: var(--paper);
  border: 1px solid var(--rule);
  padding: 8px 32px 24px;
}

.wz-step2-section {
  padding: 24px 0 0;
}

.wz-step2-section--lead {
  padding-top: 16px;
}

.wz-step2-divider {
  height: 1px;
  background: var(--rule);
  margin-bottom: 24px;
}

.wz-step2-section__head {
  margin-bottom: 18px;
}

.wz-step2-section__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
  margin-bottom: 10px;
}

.wz-step2-subhead {
  margin: 22px 0 14px;
  padding-top: 18px;
  border-top: 1px dashed var(--rule);
}

.wz-step2-subhead strong {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--ink);
  display: block;
  margin-bottom: 6px;
}

/* ── Step 1 order panel ─────────────────────────────────────── */
.wz-step1-order {
  position: sticky;
  top: 80px;
  padding: 24px;
  background: var(--bg-deep);
  border: 1px solid var(--rule);
}

.wz-order-head {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--rule);
}

.wz-order-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 48px;
}

.wz-order-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
  cursor: grab;
  user-select: none;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  color: var(--ink);
  transition: all 0.2s ease;
}

.wz-order-item:hover {
  border-color: var(--ink);
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.wz-order-item:active { cursor: grabbing; }
.wz-order-item.wz-order-item--drag-over {
  border-color: var(--accent);
  background: var(--accent-soft);
}

.wz-order-item__handle {
  font-size: 0.875rem;
  color: var(--ink-muted);
  opacity: 0.5;
}

.wz-order-item__name {
  flex: 1;
  font-weight: 600;
}

[hidden] {
  display: none !important;
}

/* ── Step 3 schedule table ───────────────────────────────────── */
.wz-schedule-table { display: flex; flex-direction: column; gap: 0; }

.wz-schedule-table__head {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  padding: 8px 16px;
  border-bottom: 2px solid var(--ink);
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.wz-schedule-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  padding: 12px 16px;
  border-bottom: 1px solid var(--rule);
  align-items: start;
}

.wz-schedule-row__name {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--ink);
  padding-top: 4px;
}

.wz-schedule-cell { display: flex; flex-direction: column; gap: 8px; }

.wz-schedule-topn {
  display: flex;
  align-items: center;
  gap: 8px;
}

.wz-schedule-topn label {
  font-size: 0.75rem;
  color: var(--ink-muted);
}

.wz-schedule-topn input {
  width: 60px;
  padding: 4px 8px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  outline: none;
}

.wz-schedule-topn input:focus { border-color: var(--accent); }

/* ── Sink fields ─────────────────────────────────────────────── */
.wz-sink-fields { display: flex; flex-direction: column; gap: 16px; margin-top: 16px; }

/* ── Theme presets ──────────────────────────────────────────── */
.wz-theme-columns {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24px;
  align-items: start;
}

.wz-theme-col {
  display: flex;
  flex-direction: column;
  gap: 18px;
  min-width: 0;
}

.wz-theme-col__label,
.wz-theme-section__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

.wz-theme-section {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 20px;
  border: 1px solid var(--rule);
  background: var(--paper);
}

.wz-preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}

.wz-theme-preview-card {
  overflow: hidden;
}

.wz-theme-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
  margin-top: 18px;
}

.wz-theme-preview {
  --preview-bg: var(--bg);
  --preview-paper: var(--paper);
  --preview-ink: var(--ink);
  --preview-soft: var(--ink-soft);
  --preview-accent: var(--accent);
  --preview-rule: var(--rule);
  --preview-glow: var(--accent-soft);
}

.wz-theme-preview__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-bottom: 10px;
}

.wz-theme-preview__surface {
  background: var(--preview-bg);
  border: 1px solid var(--preview-rule);
  padding: 18px;
  min-height: 240px;
  display: flex;
  flex-direction: column;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.wz-theme-preview__nav,
.wz-theme-preview__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.wz-theme-preview__footer {
  margin-top: auto;
}

.wz-theme-preview__brand,
.wz-theme-preview__cta {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--preview-ink);
  font-weight: 700;
}

.wz-theme-preview__badge,
.wz-theme-preview__pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  background: var(--preview-glow);
  color: var(--preview-accent);
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
}

.wz-theme-preview__hero {
  margin: 26px 0 30px;
}

.wz-theme-preview__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--preview-accent);
  font-weight: 700;
  margin-bottom: 10px;
}

.wz-theme-preview__hero h4 {
  font-family: var(--font-display);
  font-size: 1.9rem;
  line-height: 0.98;
  letter-spacing: -0.04em;
  color: var(--preview-ink);
  margin: 0 0 14px;
}

.wz-theme-preview__hero p {
  font-family: var(--font-body);
  font-size: 0.92rem;
  line-height: 1.65;
  color: var(--preview-soft);
  margin: 0;
  max-width: 28ch;
}

.wz-preset {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  border: 1px solid var(--rule);
  background: var(--bg);
  cursor: pointer;
  font-size: 0.8rem;
  color: var(--ink-soft);
  transition: border-color 0.15s;
}

.wz-preset[aria-pressed="true"] {
  border-color: var(--accent);
  color: var(--ink);
}

.wz-preset__swatch {
  width: 16px; height: 16px;
  border: 1px solid rgba(0,0,0,0.12);
  display: inline-block;
  flex-shrink: 0;
}

.wz-preset__swatch--dashed { border: 1px dashed var(--rule); background: transparent; }

.wz-custom-color {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 10px;
}

.wz-custom-color input[type="color"] {
  width: 36px; height: 28px;
  padding: 2px;
  border: 1px solid var(--rule);
  cursor: pointer;
  background: var(--bg);
}

