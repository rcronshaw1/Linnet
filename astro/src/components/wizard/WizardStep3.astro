---
interface Props {
  locale: 'en' | 'zh';
}
const { locale } = Astro.props;

const t = {
  desc: locale === 'zh'
    ? '这里只放你额外启用的 secrets 和推送渠道。没有用到的内容可以留空或直接跳过。'
    : 'This step only covers extra secrets and delivery channels. Leave unused items off and skip ahead if you do not need them.',
  quickHead: locale === 'zh' ? '先把主站点跑通也完全可以' : 'It is fine to launch the site first',
  quickDesc: locale === 'zh'
    ? '第一次部署时，Slack、Server酱和 Quote of the Day 都不是必需项。只有当你真的启用了这些能力时，下面的卡片才需要填写。'
    : 'Slack, ServerChan, and Quote of the Day are not required for the first deploy. Only fill the cards below when you actually enabled those capabilities.',
  quoteHead: locale === 'zh' ? 'Quote of the Day' : 'Quote of the Day',
  quoteDesc: locale === 'zh'
    ? '英文版 Quote of the Day 需要 API Ninjas key。只有当前面选中了这个来源时，这张卡片才会出现。'
    : 'The English Quote of the Day source needs an API Ninjas key. This card only appears when that source is enabled earlier.',
  quoteKeyLabel: locale === 'zh' ? 'API Ninjas key' : 'API Ninjas key',
  quoteHint: locale === 'zh'
    ? '会作为 API_NINJAS_KEY 写入 GitHub Actions Secrets，不会写进 YAML。'
    : 'Stored as API_NINJAS_KEY in GitHub Actions secrets and never written into YAML.',
  slackHead: 'Slack',
  slackEnable: locale === 'zh' ? '启用 Slack 推送' : 'Enable Slack delivery',
  slackDesc: locale === 'zh'
    ? '通过 Incoming Webhook 把 digest 发到 Slack。适合团队频道，或者你自己的工作区。'
    : 'Deliver the digest to Slack through an Incoming Webhook. Good for a team channel or your own workspace.',
  webhookLabel: locale === 'zh' ? 'Slack Webhook URL' : 'Slack Webhook URL',
  webhookHint: locale === 'zh'
    ? '会作为 SLACK_WEBHOOK_URL 写入 GitHub Actions Secrets，不会写进 YAML。'
    : 'Stored as SLACK_WEBHOOK_URL in GitHub Actions secrets and never written into YAML.',
  scHead: locale === 'zh' ? 'Server酱 (ServerChan)' : 'Server酱 (ServerChan)',
  scEnable: locale === 'zh' ? '启用 Server酱推送' : 'Enable ServerChan delivery',
  scDesc: locale === 'zh'
    ? '把 digest 推到你的个人通知里，常见用法是手机或微信提醒。'
    : 'Push the digest into personal notifications, often used for phone or WeChat-style alerts.',
  scKeyLabel: locale === 'zh' ? 'SendKey' : 'SendKey',
  scHint: locale === 'zh'
    ? '会作为 SERVERCHAN_SENDKEY 写入 GitHub Actions Secrets，不会写进 YAML。'
    : 'Stored as SERVERCHAN_SENDKEY in GitHub Actions secrets and never written into YAML.',
  countsHint: locale === 'zh'
    ? '这里只显示你在前面真正启用过的内容来源。'
    : 'Only the sources you enabled earlier are shown here.',
  maxPapers: locale === 'zh' ? '最多论文数' : 'Max papers',
  maxHn: locale === 'zh' ? '最多 HN 条目' : 'Max HN stories',
  maxGithub: locale === 'zh' ? '最多 GitHub 仓库' : 'Max GitHub repos',
  maxJobs: locale === 'zh' ? '最多职位数' : 'Max jobs',
};
---

<div class="wz-step" data-step="3" aria-hidden="true">
  <p class="wz-step__desc">{t.desc}</p>

  <div class="wz-notice wz-notice--info">
    <strong>{t.quickHead}</strong>
    <div>{t.quickDesc}</div>
  </div>

  <div class="wz-card-grid">
    <div class="wz-card wz-card--compact">
      <div class="wz-card__header">
        <h3>{t.slackHead}</h3>
        <label class="wz-toggle">
          <input type="checkbox" id="slack-enabled" data-sink-slack-enabled />
          <span class="wz-toggle__label">{t.slackEnable}</span>
        </label>
      </div>
      <p class="wz-card__desc">{t.slackDesc}</p>
      <div class="wz-sink-fields" data-sink-slack-fields hidden>
        <div class="wz-field">
          <label for="slack-webhook">{t.webhookLabel}</label>
          <input
            type="password"
            id="slack-webhook"
            data-deploy-secret="SLACK_WEBHOOK_URL"
            placeholder="https://hooks.slack.com/services/..."
            autocomplete="off"
          />
          <div class="wz-field__hint">{t.webhookHint}</div>
        </div>
        <div class="wz-field__hint">{t.countsHint}</div>
        <div class="wz-field-row wz-field-row--compact" style="margin-top:16px">
          <div class="wz-field" data-sink-limit-for="arxiv">
            <label for="slack-max-papers">{t.maxPapers}</label>
            <input type="number" id="slack-max-papers" data-sink-slack-max-papers min="1" max="20" value="5" />
          </div>
          <div class="wz-field" data-sink-limit-for="hacker_news">
            <label for="slack-max-hn">{t.maxHn}</label>
            <input type="number" id="slack-max-hn" data-sink-slack-max-hn min="1" max="15" value="3" />
          </div>
          <div class="wz-field" data-sink-limit-for="github_trending">
            <label for="slack-max-github">{t.maxGithub}</label>
            <input type="number" id="slack-max-github" data-sink-slack-max-github min="1" max="15" value="3" />
          </div>
        </div>
      </div>
    </div>

    <div class="wz-card wz-card--compact">
      <div class="wz-card__header">
        <h3>{t.scHead}</h3>
        <label class="wz-toggle">
          <input type="checkbox" id="sc-enabled" data-sink-sc-enabled />
          <span class="wz-toggle__label">{t.scEnable}</span>
        </label>
      </div>
      <p class="wz-card__desc">{t.scDesc}</p>
      <div class="wz-sink-fields" data-sink-sc-fields hidden>
        <div class="wz-field">
          <label for="sc-sendkey">{t.scKeyLabel}</label>
          <input
            type="password"
            id="sc-sendkey"
            data-deploy-secret="SERVERCHAN_SENDKEY"
            placeholder="SCT..."
            autocomplete="off"
          />
          <div class="wz-field__hint">{t.scHint}</div>
        </div>
        <div class="wz-field__hint">{t.countsHint}</div>
        <div class="wz-field-row wz-field-row--compact" style="margin-top:16px">
          <div class="wz-field" data-sink-limit-for="arxiv">
            <label for="sc-max-papers">{t.maxPapers}</label>
            <input type="number" id="sc-max-papers" data-sink-sc-max-papers min="1" max="20" value="5" />
          </div>
          <div class="wz-field" data-sink-limit-for="hacker_news">
            <label for="sc-max-hn">{t.maxHn}</label>
            <input type="number" id="sc-max-hn" data-sink-sc-max-hn min="1" max="15" value="3" />
          </div>
          <div class="wz-field" data-sink-limit-for="github_trending">
            <label for="sc-max-github">{t.maxGithub}</label>
            <input type="number" id="sc-max-github" data-sink-sc-max-github min="1" max="15" value="3" />
          </div>
          <div class="wz-field" data-sink-limit-for="postdoc_jobs">
            <label for="sc-max-jobs">{t.maxJobs}</label>
            <input type="number" id="sc-max-jobs" data-sink-sc-max-jobs min="1" max="10" value="3" />
          </div>
        </div>
      </div>
    </div>

    <div class="wz-card wz-card--compact" data-optional-secret-card="API_NINJAS_KEY" hidden>
      <h3>{t.quoteHead}</h3>
      <p class="wz-card__desc">{t.quoteDesc}</p>
      <div class="wz-field">
        <label for="quote-api-key">{t.quoteKeyLabel}</label>
        <input
          id="quote-api-key"
          type="password"
          data-deploy-secret="API_NINJAS_KEY"
          placeholder="..."
          autocomplete="off"
        />
        <div class="wz-field__hint">{t.quoteHint}</div>
      </div>
    </div>
  </div>
</div>
