---
import type { ExtensionMeta } from '@/lib/registry';
import { ARXIV_CATEGORIES } from '@/lib/arxivCategories';
import { ARXIV_PROFILES } from '@/lib/arxivProfiles';
import TextField     from './fields/TextField.astro';
import SliderField   from './fields/SliderField.astro';
import SelectField   from './fields/SelectField.astro';
import MultiSelectField from './fields/MultiSelectField.astro';
import TagsField     from './fields/TagsField.astro';
import UrlsField     from './fields/UrlsField.astro';

interface Props {
  extensions: ExtensionMeta[];
  locale: 'en' | 'zh';
}
const { extensions, locale } = Astro.props;

const academicProfileKeys = [
  'ai_ml',
  'cv',
  'nlp',
  'robotics',
  'medical_ai',
  'biology',
  'physics',
  'chemistry',
  'mathematics',
  'astrophysics',
] as const;

const t = {
  leadHead:       locale === 'zh' ? '已选来源的详细配置' : 'Detailed config for selected sources',
  leadDesc:       locale === 'zh'
    ? '这里只有你当前启用的来源会出现。Academic Brief 的主研究方向和 arXiv 细节现在都集中在这里，不再分散到前一步。'
    : 'Only the sources you currently enabled appear here. The Academic Brief research domain and the detailed arXiv controls now live together here.',
  arxivDesc:      locale === 'zh' ? '这里统一决定 Academic Brief 的主研究方向，以及 arXiv 的自定义类别、关键词和抓取参数。' : 'Use this panel to set the Academic Brief primary research domain and all detailed arXiv tuning in one place.',
  domainHead:     locale === 'zh' ? '主研究方向' : 'Primary research domain',
  domainDesc:     locale === 'zh'
    ? '先选一个最接近的研究 preset；如果还不够，再用下面的自定义输入继续补。'
    : 'Pick the closest research preset first, then refine it with the custom inputs below if needed.',
  customFocus:    locale === 'zh' ? '自定义方向' : 'Custom focus',
  customFocusDesc: locale === 'zh'
    ? '不套用现成 preset，主要依赖下面的自定义分类和关键词。'
    : 'Skip the preset profiles and drive arXiv mostly with the custom fields below.',
  customOnlyHead: locale === 'zh' ? '自定义方向说明' : 'Custom focus note',
  customOnlyDesc: locale === 'zh' ? '选择“自定义方向”时，下面这些输入就会成为主要过滤条件。' : 'When you choose Custom focus, the manual fields below become the primary filters.',
  customHead:     locale === 'zh' ? '自定义补充' : 'Custom additions',
  customDesc:     locale === 'zh'
    ? '如果上面选的 preset 还不够准确，可以在下面继续补充。若 categories 留空，wizard 会保留一组安全默认分类以保证抓取正常。'
    : 'If the preset above is still not specific enough, keep refining it below. If categories stay blank, the wizard keeps a safe fallback category set so fetching still works.',
  customCats:     locale === 'zh' ? '自定义分类（arXiv 分类，如 cs.LG）' : 'Custom categories (arXiv IDs, e.g. cs.LG)',
  customKws:      locale === 'zh' ? '自定义关键词（must_include）' : 'Custom keywords (must_include)',
  customBoosts:   locale === 'zh' ? '加权关键词（boost_keywords）' : 'Boost keywords',
  threshold:      locale === 'zh' ? 'LLM 评分阈值' : 'LLM score threshold',
  maxPapers:      locale === 'zh' ? '每次抓取最多论文数' : 'Max papers fetched per run',
  addTag:         locale === 'zh' ? '添加' : 'Add',
  noTag:          locale === 'zh' ? '尚未添加' : 'None added',
  noUrl:          locale === 'zh' ? '尚未添加 URL' : 'No URLs added',
  mergedProfile:  locale === 'zh' ? '生成逻辑说明' : 'Generation note',
};

const compactFieldTypes = new Set(['text', 'number', 'slider', 'select']);
const categoryLabels = {
  research: locale === 'zh' ? '学术' : 'Research',
  tech: locale === 'zh' ? '技术' : 'Tech',
  career: locale === 'zh' ? '职业' : 'Career',
  local: locale === 'zh' ? '本地' : 'Local',
  custom: locale === 'zh' ? '自定义' : 'Custom',
};
---

<div class="wz-step" data-step="2" aria-hidden="true">
  <div class="wz-step2-sheet">

    <section class="wz-step2-section wz-step2-section--lead">
      <h3>{t.leadHead}</h3>
      <p class="wz-card__desc">{t.leadDesc}</p>
    </section>

    {extensions.map(ext => {
      const name = locale === 'zh' ? (ext.displayNameZh ?? ext.displayName) : ext.displayName;
      const compactFields = ext.setupFields.filter(field => compactFieldTypes.has(field.type));
      const richFields = ext.setupFields.filter(field => !compactFieldTypes.has(field.type));
      const categoryLabel = categoryLabels[ext.category];
      return (
        <section class="wz-config-panel wz-step2-section" data-config-for={ext.key} hidden>
          <div class="wz-step2-divider" aria-hidden="true"></div>
          <div class="wz-step2-section__head">
            <div class="wz-step2-section__eyebrow">{categoryLabel}</div>
            <h3>{name}</h3>
          </div>

          {ext.key === 'arxiv' ? (
            <div>
              <p class="wz-card__desc">{t.arxivDesc}</p>
              <div class="wz-step2-subhead" style="margin-top:0; padding-top:0; border-top:none;">
                <strong>{t.domainHead}</strong>
                <div class="wz-field__hint">{t.domainDesc}</div>
              </div>

              <div class="wz-profile-grid">
                <label class="wz-profile-card">
                  <input type="radio" name="brief_arxiv_preset" value="custom_only" data-arxiv-profile-input />
                  <span class="wz-profile-card__name">{t.customFocus}</span>
                  <span class="wz-profile-card__summary">{t.customFocusDesc}</span>
                </label>
                {academicProfileKeys.map((key) => {
                  const profile = ARXIV_PROFILES[key];
                  const pLabel = locale === 'zh' ? profile.labelZh : profile.label;
                  const pSummary = locale === 'zh' ? profile.summaryZh : profile.summary;
                  return (
                    <label class="wz-profile-card">
                      <input
                        type="radio"
                        name="brief_arxiv_preset"
                        value={key}
                        data-arxiv-profile-input
                        checked={key === 'ai_ml'}
                      />
                      <span class="wz-profile-card__name">{pLabel}</span>
                      <span class="wz-profile-card__summary">{pSummary}</span>
                    </label>
                  );
                })}
              </div>

              <div class="wz-notice wz-notice--info" style="margin-top:14px">
                <strong>{t.customOnlyHead}</strong>
                <div>{t.customOnlyDesc}</div>
              </div>

              <div class="wz-step2-subhead">
                <strong>{t.customHead}</strong>
                <div class="wz-field__hint">{t.customDesc}</div>
              </div>

              <div class="wz-field-grid">
                <div class="wz-field wz-field--rich">
                  <div class="wz-field__label">{t.customKws}</div>
                  <div class="wz-tags" data-arxiv-custom-keywords data-sync-key="arxiv-custom-keywords" data-tags="[]">
                    <div class="wz-tags__list" data-tags-list>
                      <span class="wz-tags__empty">{t.noTag}</span>
                    </div>
                    <div class="wz-tags__input-row">
                      <input type="text" placeholder="e.g. hallucination" class="wz-tags__input" autocomplete="off" />
                      <button type="button" class="wz-tags__add" data-tags-add>{t.addTag}</button>
                    </div>
                  </div>
                </div>

                <div class="wz-field wz-field--rich">
                  <div class="wz-field__label">{t.customCats}</div>
                  <div class="wz-tags" data-arxiv-custom-categories data-sync-key="arxiv-custom-categories" data-tags="[]">
                    <div class="wz-tags__list" data-tags-list>
                      <span class="wz-tags__empty">{t.noTag}</span>
                    </div>
                    <div class="wz-tags__input-row">
                      <input type="text" placeholder="e.g. cs.CV" class="wz-tags__input" list="arxiv-cats-datalist" autocomplete="off" />
                      <button type="button" class="wz-tags__add" data-tags-add>{t.addTag}</button>
                    </div>
                  </div>
                </div>
                <datalist id="arxiv-cats-datalist">
                  {ARXIV_CATEGORIES.map(cat => (
                    <option value={cat.id}>{cat.id} — {cat.name} ({cat.group})</option>
                  ))}
                </datalist>

                <div class="wz-field wz-field--rich">
                  <div class="wz-field__label">{t.customBoosts}</div>
                  <div class="wz-tags" data-arxiv-custom-boosts data-sync-key="arxiv-custom-boosts" data-tags="[]">
                    <div class="wz-tags__list" data-tags-list>
                      <span class="wz-tags__empty">{t.noTag}</span>
                    </div>
                    <div class="wz-tags__input-row">
                      <input type="text" placeholder="e.g. LoRA" class="wz-tags__input" autocomplete="off" />
                      <button type="button" class="wz-tags__add" data-tags-add>{t.addTag}</button>
                    </div>
                  </div>
                </div>
              </div>

              <div class="wz-field-grid">
                <div class="wz-field">
                  <label for="arxiv-threshold">{t.threshold}</label>
                  <div class="wz-slider-row">
                    <input type="range" id="arxiv-threshold" data-arxiv-threshold min="0" max="10" step="1" value="7" />
                    <span class="wz-slider-val" data-slider-val="arxiv-threshold">7</span>
                  </div>
                </div>
                <div class="wz-field">
                  <label for="arxiv-max-papers">{t.maxPapers}</label>
                  <input type="number" id="arxiv-max-papers" data-arxiv-max-papers min="25" max="1000" step="25" value="100" />
                </div>
              </div>

              <div class="wz-notice wz-notice--success" style="margin-top:16px">
                <strong>{t.mergedProfile}</strong>
                <div class="wz-field__hint">
                  {locale === 'zh'
                    ? '最终配置会基于一个主预设加上你的自定义项生成；如果选择“仅自定义”，就主要使用你下面填写的内容；若没填 categories，会回退到安全默认分类。'
                    : 'The final config combines one primary preset with your custom additions. If you choose Custom only, the wizard mainly uses your manual inputs; when categories are blank, it falls back to a safe default category set.'}
                </div>
              </div>
            </div>
          ) : (
            <div class="wz-field-stack">
              {compactFields.length > 0 && (
                <div class="wz-field-grid">
                  {compactFields.map(field => {
                    if (field.type === 'text')        return <TextField     {field} extKey={ext.key} {locale} />;
                    if (field.type === 'number')      return <TextField     {field} extKey={ext.key} {locale} />;
                    if (field.type === 'slider')      return <SliderField   {field} extKey={ext.key} {locale} />;
                    if (field.type === 'select')      return <SelectField   {field} extKey={ext.key} {locale} />;
                    return null;
                  })}
                </div>
              )}

              {richFields.map(field => {
                if (field.type === 'text')        return <TextField     {field} extKey={ext.key} {locale} />;
                if (field.type === 'number')      return <TextField     {field} extKey={ext.key} {locale} />;
                if (field.type === 'slider')      return <SliderField   {field} extKey={ext.key} {locale} />;
                if (field.type === 'select')      return <SelectField   {field} extKey={ext.key} {locale} />;
                if (field.type === 'multiselect') return <MultiSelectField {field} extKey={ext.key} {locale} />;
                if (field.type === 'tags')        return <TagsField     {field} extKey={ext.key} {locale} />;
                if (field.type === 'urls')        return <UrlsField     {field} extKey={ext.key} {locale} />;
                return null;
              })}
            </div>
          )}
        </section>
      );
    })}

  </div>
</div>
