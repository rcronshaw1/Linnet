---
interface Props {
  name: string;
  size?: number;
  color?: string;
  strokeWidth?: number;
}

const { name, size = 20, color = 'currentColor', strokeWidth = 1.6 } = Astro.props;

const paths: Record<string, string> = {
  paper:   '<path d="M6 3h9l4 4v14H6z"/><path d="M15 3v4h4"/><path d="M9 11h5M9 14h6M9 17h4"/>',
  flame:   '<path d="M12 3c0 3.5 3.5 4.5 3.5 8a5.5 5.5 0 0 1-11 0c0-2 1-3.5 2-4.5 0 1.5.5 2.5 1.5 2.5 0-3 1.5-4 4-6z"/>',
  repo:    '<path d="M5 4.5A1.5 1.5 0 0 1 6.5 3h11v16h-11A1.5 1.5 0 0 1 5 17.5zM5 17.5A1.5 1.5 0 0 1 6.5 16h11v5h-11A1.5 1.5 0 0 1 5 19.5z"/><path d="M9 7h5"/>',
  post:    '<rect x="3.5" y="5.5" width="17" height="13" rx="1"/><path d="M3.5 9h17M8 13h5M8 16h8"/>',
  cloud:   '<path d="M7 18a4 4 0 0 1 0-8 5 5 0 0 1 9.5 1.5A3.5 3.5 0 0 1 17 18z"/><circle cx="17.5" cy="7" r="2.2"/>',
  feather: '<path d="M19 5c0 8-7 14-12 14l-2-2C9 17 15 11 15 5c2 0 4 0 4 0z"/><path d="M17 7 8 16"/>',
  sun:     '<circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.5 5.5l1.4 1.4M17.1 17.1l1.4 1.4M5.5 18.5l1.4-1.4M17.1 6.9l1.4-1.4"/>',
  moon:    '<path d="M20 14.5A8 8 0 0 1 9.5 4a8 8 0 1 0 10.5 10.5z"/>',
  arrow:   '<path d="M5 12h14M13 6l6 6-6 6"/>',
  search:  '<circle cx="11" cy="11" r="6.5"/><path d="m16 16 4 4"/>',
  book:    '<path d="M4 5a2 2 0 0 1 2-2h14v16H6a2 2 0 0 0-2 2z"/><path d="M4 5v16"/>',
  menu:    '<path d="M4 7h16M4 12h16M4 17h16"/>',
};

const svgContent = paths[name] ?? paths['arrow'];
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke={color}
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={svgContent}
/>
