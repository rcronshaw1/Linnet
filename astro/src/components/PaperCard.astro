---
/**
 * PaperCard — 3-tier editorial layout.
 *
 * Tier 1 (idx 0):   PaperLead   — full-width, drop cap, Seal badge, figure right
 * Tier 2 (idx 1-4): PaperWithFig — alternating left/right figure, 2-column
 * Tier 3 (idx 5-9): PaperCompact — 2-column mini-card grid (set from SectionBlock)
 */

interface Props {
  paper: {
    id?: string;
    title: string;
    authors?: string[];
    categories?: string[];
    abstract?: string;
    url?: string;
    pdf_url?: string;
    score?: number;
    figure_url?: string;
    figure_caption?: string;
    primary_category?: string;
    summary?: string;
    _idx?: number;
  };
  item?: Record<string, unknown>;
  _idx?: number;
}

const { paper, _idx } = Astro.props;

const idx       = _idx ?? (paper._idx as number | undefined) ?? 0;
const abstract  = String(paper.abstract ?? paper.summary ?? '');
const authors   = paper.authors ?? [];
const leadAuthors = authors.join(', ');
const shortAuthors = authors.slice(0, 2).join(', ') + (authors.length > 2 ? ' et al.' : '');
const category  = paper.primary_category ?? (paper.categories ?? [])[0] ?? '';
const score     = paper.score;
const url       = paper.url;
const pdfUrl    = paper.pdf_url;
const hasFig    = Boolean(paper.figure_url);
const figSide   = idx % 2 === 1 ? 'left' : 'right';
---

{idx === 0 && (
  <div class="paper-lead">
    <div class="paper-lead__kicker">
      {category && <span class="paper-cat">{category}</span>}
      {paper.id && <span>arxiv:{paper.id}</span>}
      <span>Lead article</span>
    </div>

    <h2 class="paper-lead__title">
      {url ? <a href={url} target="_blank" rel="noopener">{paper.title}</a> : paper.title}
    </h2>

    {leadAuthors && <p class="paper-lead__authors">{leadAuthors}</p>}

    <div class={`paper-lead__body ${hasFig ? 'paper-lead__body--with-fig' : ''}`}>
      <div class="paper-lead__text">
        <p class="paper-lead__abstract">
          {abstract.length > 0 && (
            <span class="paper-lead__dropcap" aria-hidden="true">{abstract[0]}</span>
          )}
          {abstract.slice(1)}
        </p>
        <div class="paper-lead__links">
          {url && <a href={url} target="_blank" rel="noopener" class="paper-link">Read abstract →</a>}
          {pdfUrl && <a href={pdfUrl} target="_blank" rel="noopener" class="paper-link paper-link--dim">Full PDF</a>}
          {score != null && (
            <svg class="paper-seal" width="68" height="68" viewBox="0 0 88 88">
              <circle cx="44" cy="44" r="41" fill="none" stroke="var(--accent)" stroke-width="1.5"/>
              <circle cx="44" cy="44" r="36" fill="none" stroke="var(--accent)" stroke-width="0.6"/>
              <path d="M 44 10 A 34 34 0 0 1 78 44" fill="none" id="seal-path"/>
              <text font-family="JetBrains Mono,monospace" font-size="8" letter-spacing="2" fill="var(--accent)">
                <textPath href="#seal-path" startOffset="8">LINNET · SCORE</textPath>
              </text>
              <text x="44" y="48" text-anchor="middle" font-family="Fraunces,Georgia,serif" font-size="22" font-weight="700" fill="var(--ink)">{score.toFixed(0)}</text>
              <text x="44" y="60" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7" letter-spacing="1.5" fill="var(--accent)">RELEVANCE</text>
            </svg>
          )}
        </div>
      </div>

      {hasFig && (
        <figure class="paper-fig">
          <div class="paper-fig__frame">
            <img src={paper.figure_url} alt={paper.figure_caption ?? paper.title} loading="lazy" />
          </div>
          {paper.figure_caption && (
            <figcaption class="paper-fig__caption">
              {paper.figure_caption.length > 280 ? paper.figure_caption.slice(0, 280) + '…' : paper.figure_caption}
            </figcaption>
          )}
        </figure>
      )}
    </div>
  </div>
)}

{idx >= 1 && idx <= 4 && (
  <div class={hasFig ? `paper-fig-row paper-fig-row--${figSide}` : 'paper-fig-row paper-fig-row--nofig'}>
    {hasFig && figSide === 'left' && (
      <figure class="paper-fig">
        <div class="paper-fig__frame">
          <img src={paper.figure_url} alt={paper.figure_caption ?? paper.title} loading="lazy" />
        </div>
        {paper.figure_caption && (
          <figcaption class="paper-fig__caption">
            {paper.figure_caption.length > 200 ? paper.figure_caption.slice(0, 200) + '…' : paper.figure_caption}
          </figcaption>
        )}
      </figure>
    )}

    <div class="paper-fig-row__body">
      <div class="paper-text__kicker">
        {category && <span class="paper-cat">{category}</span>}
        {paper.id && <span>arxiv:{paper.id}</span>}
      </div>
      <h3 class="paper-fig-row__title">
        {url ? <a href={url} target="_blank" rel="noopener">{paper.title}</a> : paper.title}
      </h3>
      {shortAuthors && <p class="paper-authors">{shortAuthors}</p>}
      {abstract && <p class="paper-fig-row__abstract">{abstract.length > 260 ? abstract.slice(0, 260) + '…' : abstract}</p>}
      <div class="paper-text__links">
        {url && <a href={url} target="_blank" rel="noopener" class="paper-link">abstract</a>}
        {pdfUrl && <a href={pdfUrl} target="_blank" rel="noopener" class="paper-link paper-link--dim">pdf</a>}
        {score != null && (
          <svg class="paper-seal paper-seal--sm" width="44" height="44" viewBox="0 0 88 88">
            <circle cx="44" cy="44" r="41" fill="none" stroke="var(--accent)" stroke-width="1.5"/>
            <circle cx="44" cy="44" r="36" fill="none" stroke="var(--accent)" stroke-width="0.6"/>
            <path d={`M 44 10 A 34 34 0 0 1 78 44`} fill="none" id={`seal-path-${idx}`}/>
            <text font-family="JetBrains Mono,monospace" font-size="8" letter-spacing="2" fill="var(--accent)">
              <textPath href={`#seal-path-${idx}`} startOffset="8">LINNET · SCORE</textPath>
            </text>
            <text x="44" y="48" text-anchor="middle" font-family="Fraunces,Georgia,serif" font-size="22" font-weight="700" fill="var(--ink)">{score.toFixed(0)}</text>
            <text x="44" y="60" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="7" letter-spacing="1.5" fill="var(--accent)">RELEVANCE</text>
          </svg>
        )}
      </div>
    </div>

    {hasFig && figSide === 'right' && (
      <figure class="paper-fig">
        <div class="paper-fig__frame">
          <img src={paper.figure_url} alt={paper.figure_caption ?? paper.title} loading="lazy" />
        </div>
        {paper.figure_caption && (
          <figcaption class="paper-fig__caption">
            {paper.figure_caption.length > 200 ? paper.figure_caption.slice(0, 200) + '…' : paper.figure_caption}
          </figcaption>
        )}
      </figure>
    )}
  </div>
)}

{idx >= 5 && (
  <div class="paper-compact">
    <div class="paper-compact__header">
      <div class="paper-compact__num">№{String(idx + 1).padStart(2, '0')}</div>
      <div class="paper-compact__cats">
        {category && <span class="paper-compact__cat">{category}</span>}
      </div>
      {score != null && (
        <div class="paper-compact__score">{score.toFixed(0)}</div>
      )}
    </div>
    <h4 class="paper-compact__title">
      {url ? <a href={url} target="_blank" rel="noopener">{paper.title}</a> : paper.title}
    </h4>
    {shortAuthors && <p class="paper-authors paper-authors--sm">{shortAuthors}</p>}
    {abstract && (
      <p class="paper-compact__abstract">
        {abstract.length > 180 ? abstract.slice(0, 180) + '…' : abstract}
      </p>
    )}
    <div class="paper-compact__links">
      {url && <a href={url} target="_blank" rel="noopener" class="paper-link paper-link--sm">abstract</a>}
      {pdfUrl && <a href={pdfUrl} target="_blank" rel="noopener" class="paper-link paper-link--dim paper-link--sm">pdf</a>}
    </div>
  </div>
)}

<style>
/* ── Shared atoms ─────────────────────────────────────── */
.paper-cat {
  color: var(--accent);
  font-weight: 700;
}

.paper-score {
  color: var(--accent);
  font-weight: 700;
  font-size: 0.85rem;
  margin-left: auto;
}

.paper-authors {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 0.84rem;
  color: var(--ink-muted);
  margin: 6px 0 0;
}

.paper-authors--sm {
  font-size: 0.75rem;
  margin: 3px 0 0;
}

/* figure: contain so tall images don't overflow, cap height */
.paper-fig__frame {
  border: 1px solid var(--rule);
  background: var(--paper);
  padding: 4px;
  overflow: hidden;
}

.paper-fig__frame img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: contain;
  object-position: center top;
}

.paper-fig img {
  cursor: zoom-in;
}

.medium-zoom-image--opened {
  cursor: zoom-out;
}

.paper-fig__caption {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 0.78rem;
  color: var(--ink-muted);
  margin-top: 6px;
  line-height: 1.4;
}

.paper-link {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px solid var(--accent);
  padding-bottom: 1px;
}

.paper-link--dim {
  color: var(--ink);
  border-bottom-color: var(--ink);
}

.paper-link--sm { font-size: 0.62rem; }

.paper-link:hover { opacity: 0.7; text-decoration: none; }

/* ── Tier 1: Lead ─────────────────────────────────────── */
.paper-lead {
  padding: 28px 0 36px;
  border-bottom: 1px solid var(--rule);
}

.paper-lead__kicker {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  display: flex;
  gap: 10px;
  align-items: center;
  margin-bottom: 10px;
}

.paper-lead__kicker span + span::before {
  content: '·';
  margin-right: 10px;
  color: var(--rule);
}

.paper-lead__title {
  font-family: var(--font-display);
  font-size: 2.375rem;
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.1;
  color: var(--ink);
  margin: 0 0 10px;
  max-width: 820px;
}

.paper-lead__title a { color: inherit; text-decoration: none; }
.paper-lead__title a:hover { color: var(--accent); text-decoration: none; }

.paper-lead__body {
  margin-top: 22px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.paper-lead__body--with-fig {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 32px;
  align-items: start;
}

.paper-lead__abstract {
  font-family: var(--font-body);
  font-size: 1rem;
  line-height: 1.7;
  color: var(--ink);
  margin: 0;
}

.paper-lead__dropcap {
  float: left;
  font-family: var(--font-display);
  font-size: 3.875rem;
  line-height: 0.82;
  font-weight: 700;
  padding: 6px 10px 0 0;
  color: var(--accent);
}

.paper-lead__links {
  margin-top: 18px;
  display: flex;
  align-items: center;
  gap: 18px;
  flex-wrap: wrap;
}

.paper-seal { margin-left: auto; }
.paper-seal--sm { flex-shrink: 0; }

/* ── Tier 2: WithFig ──────────────────────────────────── */
.paper-fig-row {
  padding: 26px 0;
  border-bottom: 1px solid var(--rule);
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 32px;
  align-items: start;
}

.paper-fig-row--right {
  grid-template-columns: 1fr 300px;
}

.paper-fig-row--nofig {
  grid-template-columns: 1fr;
}

.paper-text__kicker {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  display: flex;
  gap: 8px;
  align-items: center;
  margin-bottom: 8px;
}

.paper-fig-row__title {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 600;
  letter-spacing: -0.015em;
  line-height: 1.2;
  color: var(--ink);
  margin: 0 0 6px;
}

.paper-fig-row__title a { color: inherit; text-decoration: none; }
.paper-fig-row__title a:hover { color: var(--accent); text-decoration: none; }

.paper-fig-row__abstract {
  font-family: var(--font-body);
  font-size: 0.94rem;
  color: var(--ink-soft);
  line-height: 1.65;
  margin: 10px 0 0;
}

.paper-text__links {
  margin-top: 14px;
  display: flex;
  gap: 16px;
  align-items: center;
}

/* ── Tier 3: Compact 2-col mini-card ──────────────────── */
.paper-compact {
  padding: 16px 18px;
  border: 1px solid var(--rule);
  background: var(--paper);
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.paper-compact__header {
  display: flex;
  align-items: center;
  gap: 8px;
}

.paper-compact__num {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  color: var(--ink-muted);
  flex-shrink: 0;
}

.paper-compact__cats {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  flex: 1;
}

.paper-compact__cat {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
}

.paper-compact__score {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: -0.02em;
  flex-shrink: 0;
}

.paper-compact__title {
  font-family: var(--font-display);
  font-size: 0.975rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  line-height: 1.3;
  color: var(--ink);
  margin: 0;
  /* clip to 2 lines */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.paper-compact__title a { color: inherit; text-decoration: none; }
.paper-compact__title a:hover { color: var(--accent); text-decoration: none; }

.paper-compact__abstract {
  font-family: var(--font-body);
  font-size: 0.81rem;
  color: var(--ink-soft);
  line-height: 1.55;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.paper-compact__links {
  display: flex;
  gap: 10px;
  margin-top: 4px;
}

/* ── Responsive ───────────────────────────────────────── */
@media (max-width: 768px) {
  .paper-lead__body--with-fig { grid-template-columns: 1fr; }
  .paper-lead__title { font-size: 1.75rem; }
  .paper-fig-row,
  .paper-fig-row--right { grid-template-columns: 1fr; }
  .paper-seal { display: none; }
}
</style>
