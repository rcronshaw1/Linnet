---
import NavBar from '@/components/NavBar.astro';
import '@/styles/global.css';
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: string;
}

const {
  title,
  description = 'Daily AI/CV/Medical Imaging research updates — auto-generated at UK midnight',
  ogImage,
  lang = 'en',
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const shouldForceFreshDigest = pathSegments.some((segment) => ['daily', 'weekly', 'monthly'].includes(segment));

// Read site-owner color theme from sources.yaml (theme: block)
const THEME_VARS: Record<string, string> = {
  bg: '--bg', 'bg-deep': '--bg-deep', paper: '--paper',
  ink: '--ink', 'ink-soft': '--ink-soft', 'ink-muted': '--ink-muted',
  accent: '--accent', 'accent-deep': '--accent-deep',
  gold: '--gold', sage: '--sage',
};
let themeOverrideCss = '';
try {
  const yaml = await readFile(resolve(process.cwd(), '../config/sources.yaml'), 'utf-8');
  const parseBlock = (block: string) =>
    block.split('\n').filter(Boolean)
      .map(l => { const m = l.match(/^\s*([\w-]+):\s*["']?(#[0-9a-fA-F]{3,8})["']?/); return m ? `  ${THEME_VARS[m[1]] ?? '--' + m[1]}: ${m[2]};` : null; })
      .filter(Boolean) as string[];
  const themeMatch = yaml.match(/^theme:\s*\n((?:[ \t]+\S.*\n?)*)/m);
  if (themeMatch) {
    const overrides = parseBlock(themeMatch[1]);
    if (overrides.length) themeOverrideCss = `:root {\n${overrides.join('\n')}\n}`;
  }
  const themeDarkMatch = yaml.match(/^theme_dark:\s*\n((?:[ \t]+\S.*\n?)*)/m);
  if (themeDarkMatch) {
    const darkOverrides = parseBlock(themeDarkMatch[1]);
    if (darkOverrides.length) themeOverrideCss += `\n[data-theme="dark"] {\n${darkOverrides.join('\n')}\n}`;
  }
} catch {}
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <meta name="generator" content={Astro.generator} />
  <title>{title} — Linnet</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {shouldForceFreshDigest && (
    <>
      <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0" />
      <meta http-equiv="Pragma" content="no-cache" />
      <meta http-equiv="Expires" content="0" />
    </>
  )}
  <!-- OG -->
  <meta property="og:title" content={`${title} — Linnet`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {themeOverrideCss && <style set:html={themeOverrideCss}></style>}
  <slot name="head" />
  <!-- Theme init: prevent flash -->
  <script is:inline>
    const t = localStorage.getItem('theme') || 'light';
    document.documentElement.dataset.theme = t;
  </script>
  {shouldForceFreshDigest && (
    <script is:inline>
      (() => {
        const url = new URL(window.location.href);
        if (url.searchParams.has('_fresh_digest')) return;
        url.searchParams.set('_fresh_digest', String(Date.now()));
        window.location.replace(url.toString());
      })();
    </script>
  )}
</head>
<body>
  <NavBar lang={lang} />
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="page-wrap">
      <p>Auto-generated by <a href="https://github.com/YuyangXueEd/linnet">Linnet</a> · <a href={`${base}/support/`}>Support the project</a></p>
    </div>
  </footer>
</body>
</html>

<style>
.site-footer {
  margin-top: 4rem;
  padding: 1.5rem 0;
  border-top: 1px solid var(--rule);
  text-align: center;
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.site-footer a {
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px solid var(--accent);
  padding-bottom: 1px;
}

.site-footer a:hover { opacity: 0.7; text-decoration: none; }
</style>
