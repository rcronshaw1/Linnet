---
import Base from '@/layouts/Base.astro';
import SectionBlock from '@/components/SectionBlock.astro';
import { readdir, readFile } from 'node:fs/promises';
import { resolve } from 'node:path';

declare const __DATA_ROOT__: string;
const DATA_DIR = resolve(__DATA_ROOT__, 'daily');

export async function getStaticPaths() {
  const dir = resolve(__DATA_ROOT__, 'daily');
  const files = await readdir(dir);
  return files
    .filter((f: string) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
    .map((f: string) => ({ params: { date: f.replace('.json', '') } }));
}

const { date } = Astro.params;
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const data: any = JSON.parse(await readFile(resolve(DATA_DIR, `${date}.json`), 'utf-8'));

interface Section {
  key: string;
  payload_key?: string;
  title: string;
  icon?: string;
  items: Record<string, unknown>[];
  meta?: Record<string, unknown>;
}

const allSections: Section[] = data.sections_ordered ?? [];
const meta: Record<string, unknown> = data.meta ?? {};

// Sections that go into the header/tagline
const HEADER_KEYS = new Set(['quote_of_day', 'hitokoto']);

// Extract weather to always show at the top of the body
const weatherSection = allSections.find(s => s.key === 'weather' && s.items?.length > 0);

// Extract quote for tagline
const quoteSection = allSections.find(s => HEADER_KEYS.has(s.key) && s.items?.length);
const quoteItem = quoteSection?.items?.[0] as { quote?: string; author?: string; source?: string } | undefined;
const taglineText = quoteItem?.quote ?? 'A private morning briefing, compiled while you slept.';
const taglineAttr = quoteItem?.author || quoteItem?.source
  ? `— ${quoteItem.author || quoteItem.source}`
  : null;

// Feed sections exclude header extensions AND weather (handled separately) AND empty sections
const sections = allSections.filter(s =>
  !HEADER_KEYS.has(s.key) &&
  s.key !== 'weather' &&
  (s.items && s.items.length > 0)
);

const totalItems = sections.reduce((n, s) => n + (s.items?.length ?? 0), 0);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allFiles = await readdir(DATA_DIR);
const allDates = allFiles
  .filter((f: string) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
  .map((f: string) => f.replace('.json', ''))
  .sort();
const dateIdx = allDates.indexOf(date as string);
const prevDate = dateIdx > 0 ? allDates[dateIdx - 1] : null;
const nextDate = dateIdx < allDates.length - 1 ? allDates[dateIdx + 1] : null;

const issueNo = dateIdx + 1;

const dateParts = (date as string).split('-');
const day   = dateParts[2] ?? '';
const month = dateParts[1] ?? '';
const dateHuman = (() => {
  try {
    return new Date(`${date}T12:00:00`).toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
  } catch { return date as string; }
})();

const generatedAt = String(meta.generated_at ?? data.generated_at ?? '').slice(0, 16).replace('T', ' ');
const llmModel    = String(meta.llm_model ?? data.llm_model ?? '');

const ROMAN = ['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII'];
const navSections = sections
  .filter(s => s.items?.length)
  .map((s, i) => ({
    ...s,
    roman: ROMAN[i] ?? String(i + 1),
    anchorId: s.key.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
  }));
const totalSections = navSections.length;
---

<Base title={`${date} — Linnet Daily`} description={`Linnet daily digest for ${date}`}>

  <!-- ── Reading progress bar ───────────────────────────── -->
  <div class="progress-bar" id="reading-progress" aria-hidden="true"></div>

  <div class="page-wrap">

    <!-- ── Masthead ─────────────────────────────────────────── -->
    <header class="masthead" id="page-top">
      <div class="masthead__left">
        <div class="masthead__issue-label">Daily Issue</div>
        <div class="masthead__vol">Vol. I — No. {issueNo}</div>
      </div>

      <div class="masthead__center">
        <div class="masthead__date-display">
          {day} <span class="masthead__dot">·</span> {month}
        </div>
        <div class="masthead__date-human">{dateHuman}</div>
      </div>

      <div class="masthead__right">
        {generatedAt && <div>Generated {generatedAt}</div>}
        {llmModel && <div>{llmModel}</div>}
      </div>
    </header>

    <!-- ── Tagline bar ──────────────────────────────────────── -->
    <div class="tagline-bar">
      <span class="tagline-bar__text">
        {taglineText}
        {taglineAttr && <span class="tagline-bar__attr">{taglineAttr}</span>}
      </span>
      <span class="tagline-bar__count">{totalItems} items · {navSections.length} sections</span>
    </div>

    <!-- ── Section jump bar (initial) ─────────────────────── -->
    <div class="section-jump" id="section-jump-bar">
      {navSections.map(s => (
        <a href={`#${s.anchorId}`} class="section-jump__link" data-section={s.anchorId}>
          <span class="section-jump__roman">§{s.roman}</span>
          {s.title}
          <span class="section-jump__count">({s.items.length})</span>
        </a>
      ))}
    </div>

    <!-- ── Sticky section strip (appears on scroll) ────────── -->
    <div class="section-strip" id="section-strip" aria-label="Section navigation">
      <a href="#page-top" class="section-strip__home" title="Back to top">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
      </a>
      <div class="section-strip__items">
        {weatherSection && (
          <a href="#section-weather" class="section-strip__item" data-section="weather">
            <span class="section-strip__roman">§0</span>
            <span class="section-strip__name">Weather</span>
          </a>
        )}
        {navSections.map(s => (
          <a href={`#${s.anchorId}`} class="section-strip__item" data-section={s.anchorId}>
            <span class="section-strip__roman">§{s.roman}</span>
            <span class="section-strip__name">{s.title}</span>
          </a>
        ))}
      </div>
      <div class="section-strip__pager">
        <button class="strip-btn" id="strip-prev" aria-label="Previous section">‹</button>
        <button class="strip-btn" id="strip-next" aria-label="Next section">›</button>
      </div>
    </div>

    <!-- ── Content ───────────────────────────────────────────── -->
    <div class="digest-body">
      {weatherSection && (
        <div id="section-weather" class="digest-section digest-section--weather">
          <SectionBlock
            section={weatherSection}
            roman="0"
            sectionIndex={-1}
            totalSections={totalSections}
          />
        </div>
      )}

      {sections.map((section, i) => (
        <div id={navSections[i]?.anchorId} class:list={['digest-section', { 'digest-section--ruled': i > 0 || weatherSection }]}>
          <SectionBlock
            section={section}
            roman={ROMAN[i]}
            sectionIndex={i}
            totalSections={totalSections}
          />
        </div>
      ))}
    </div>

    <!-- ── Bottom nav ───────────────────────────────────────── -->
    <nav class="digest-nav">
      {prevDate
        ? <a href={`${base}/daily/${prevDate}/`} class="digest-nav__link">← {prevDate}</a>
        : <span />
      }
      <a href={`${base}/daily/`} class="digest-nav__link digest-nav__link--accent">View archive</a>
      {nextDate
        ? <a href={`${base}/daily/${nextDate}/`} class="digest-nav__link digest-nav__link--muted">{nextDate} →</a>
        : <span class="digest-nav__link digest-nav__link--muted">Next issue tomorrow</span>
      }
    </nav>

    <!-- ── Colophon ──────────────────────────────────────────── -->
    <div class="colophon">
      compiled overnight{llmModel ? ` by ${llmModel}` : ''} · end of issue no. {issueNo} · thank you for reading
    </div>

  </div>

  <!-- ── Back to top button ───────────────────────────────── -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 19V5M5 12l7-7 7 7"/>
    </svg>
  </button>

</Base>

<!-- ── Client-side navigation script ─────────────────── -->
<script>
  (function() {
    // Collect all section anchor IDs in order
    const sectionIds: string[] = [];
    document.querySelectorAll<HTMLElement>('.feed-section[id]').forEach(el => {
      sectionIds.push(el.id);
    });

    // ── Progress bar ─────────────────────────────────────────
    const progressBar = document.getElementById('reading-progress');
    function updateProgress() {
      if (!progressBar) return;
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      progressBar.style.width = docHeight > 0 ? `${(scrollTop / docHeight) * 100}%` : '0%';
    }

    // ── Sticky section strip ─────────────────────────────────
    const strip     = document.getElementById('section-strip');
    const jumpBar   = document.getElementById('section-jump-bar');
    const stripItems = document.querySelectorAll<HTMLElement>('.section-strip__item');

    function setActiveSection(id: string) {
      stripItems.forEach(item => {
        item.classList.toggle('active', item.dataset.section === id);
      });
    }

    // Show strip when jump bar scrolls out of view
    const jumpObserver = new IntersectionObserver(([entry]) => {
      strip?.classList.toggle('visible', !entry.isIntersecting);
    }, { threshold: 0 });
    if (jumpBar) jumpObserver.observe(jumpBar);

    // Track current section via IntersectionObserver
    const sectionEls = Array.from(document.querySelectorAll<HTMLElement>('.feed-section[id]'));
    const sectionObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) setActiveSection(entry.target.id);
      });
    }, { rootMargin: '-15% 0px -70% 0px', threshold: 0 });
    sectionEls.forEach(el => sectionObserver.observe(el));

    // ── Back to top ──────────────────────────────────────────
    const topBtn = document.getElementById('back-to-top');
    function updateTopBtn() {
      topBtn?.classList.toggle('visible', window.scrollY > 500);
    }
    topBtn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // ── Scroll handler (throttled) ───────────────────────────
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateProgress();
          updateTopBtn();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // ── Page turn: prev / next buttons in strip ──────────────
    function currentSectionIdx(): number {
      const active = document.querySelector<HTMLElement>('.section-strip__item.active');
      if (!active) return 0;
      return sectionIds.indexOf(active.dataset.section ?? '');
    }

    function jumpToSection(idx: number) {
      const id = sectionIds[idx];
      if (!id) return;
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    document.getElementById('strip-prev')?.addEventListener('click', () => {
      jumpToSection(Math.max(0, currentSectionIdx() - 1));
    });
    document.getElementById('strip-next')?.addEventListener('click', () => {
      jumpToSection(Math.min(sectionIds.length - 1, currentSectionIdx() + 1));
    });

    // ── Per-section turn buttons ─────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.turn-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetIdx = parseInt(btn.dataset.targetIdx ?? '0', 10);
        jumpToSection(targetIdx);
      });
    });

    // ── Keyboard navigation (← / →) ─────────────────────────
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      // Don't hijack when focus is in an input/textarea
      const tag = (e.target as HTMLElement).tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;

      if (e.key === 'ArrowRight' || e.key === ']') {
        e.preventDefault();
        jumpToSection(Math.min(sectionIds.length - 1, currentSectionIdx() + 1));
      } else if (e.key === 'ArrowLeft' || e.key === '[') {
        e.preventDefault();
        jumpToSection(Math.max(0, currentSectionIdx() - 1));
      }
    });
    // ── Image Zoom ───────────────────────────────────────────
    const zoomScript = document.createElement('script');
    zoomScript.src = 'https://cdn.jsdelivr.net/npm/medium-zoom/dist/medium-zoom.min.js';
    zoomScript.onload = () => {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      (window as any).mediumZoom('.paper-fig img', {
        background: 'var(--paper)',
        margin: 24,
      });
    };
    document.head.appendChild(zoomScript);
  })();
</script>

<style>
/* ── Reading progress bar ──────────────────────────────── */
.progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  width: 0%;
  background: var(--accent);
  z-index: 9999;
  transition: width 0.1s linear;
  pointer-events: none;
}

/* ── Masthead ──────────────────────────────────────────── */
.masthead {
  padding: 48px 0 24px;
  border-bottom: 2px solid var(--ink);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: end;
  gap: 24px;
}

.masthead__left {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-muted);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.masthead__issue-label { color: var(--accent); font-weight: 700; }
.masthead__center { text-align: center; }

.masthead__date-display {
  font-family: var(--font-display);
  font-size: clamp(3rem, 8vw, 4.5rem);
  font-weight: 700;
  letter-spacing: -0.04em;
  line-height: 0.92;
  color: var(--ink);
}

.masthead__dot { color: var(--accent); }

.masthead__date-human {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-top: 8px;
}

.masthead__right {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ink-muted);
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* ── Tagline bar ───────────────────────────────────────── */
.tagline-bar {
  padding: 14px 0;
  border-bottom: 1px solid var(--rule);
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16px;
}

.tagline-bar__text {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 0.94rem;
  color: var(--ink-soft);
  display: flex;
  gap: 8px;
  align-items: baseline;
  flex-wrap: wrap;
}

.tagline-bar__attr {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-style: normal;
}

.tagline-bar__count {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
  white-space: nowrap;
}

/* ── Section jump bar ──────────────────────────────────── */
.section-jump {
  padding: 12px 0;
  border-bottom: 1px solid var(--rule);
  display: flex;
  gap: 18px;
  overflow-x: auto;
  scrollbar-width: none;
}

.section-jump::-webkit-scrollbar { display: none; }

.section-jump__link {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  text-decoration: none;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: color 0.15s;
}

.section-jump__link:hover { color: var(--ink); text-decoration: none; }
.section-jump__roman { color: var(--accent); }
.section-jump__count { color: var(--rule); }

/* ── Sticky section strip ──────────────────────────────── */
.section-strip {
  position: sticky;
  top: 0;
  z-index: 200;
  background: var(--paper);
  border-bottom: 1px solid var(--ink);
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0;
  /* hidden by default — JS adds .visible when jump bar scrolls out */
  opacity: 0;
  pointer-events: none;
  transform: translateY(-100%);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.section-strip.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.section-strip__home {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  color: var(--ink-muted);
  text-decoration: none;
  border-right: 1px solid var(--rule);
  flex-shrink: 0;
  transition: color 0.15s;
}

.section-strip__home:hover { color: var(--accent); text-decoration: none; }

.section-strip__items {
  display: flex;
  overflow-x: auto;
  scrollbar-width: none;
  flex: 1;
}

.section-strip__items::-webkit-scrollbar { display: none; }

.section-strip__item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 14px;
  height: 44px;
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  text-decoration: none;
  white-space: nowrap;
  border-right: 1px solid var(--rule);
  transition: color 0.15s, background 0.15s;
}

.section-strip__item:hover { color: var(--ink); text-decoration: none; }

.section-strip__item.active {
  color: var(--accent);
  background: color-mix(in srgb, var(--accent) 6%, var(--paper));
}

.section-strip__roman {
  font-size: 0.75rem;
  font-weight: 700;
  color: inherit;
}

.section-strip__name { color: inherit; }

.section-strip__pager {
  display: flex;
  border-left: 1px solid var(--rule);
  flex-shrink: 0;
}

.strip-btn {
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  border-right: 1px solid var(--rule);
  cursor: pointer;
  font-family: var(--font-mono);
  font-size: 1.1rem;
  color: var(--ink-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.15s, background 0.15s;
}

.strip-btn:last-child { border-right: none; }
.strip-btn:hover { color: var(--accent); background: color-mix(in srgb, var(--accent) 5%, var(--paper)); }

/* ── Digest body ───────────────────────────────────────── */
.digest-body { margin-top: 0; }

.digest-section:first-child { padding-top: 20px; }

.digest-section--ruled {
  border-top: 3px double var(--ink);
  padding-top: 36px;
}


/* ── Bottom nav ────────────────────────────────────────── */
.digest-nav {
  padding: 32px 0 48px;
  border-top: 1px solid var(--ink);
  margin-top: 40px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.digest-nav__link {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 1px solid var(--ink);
  padding-bottom: 2px;
  transition: opacity 0.15s;
}

.digest-nav__link:hover { opacity: 0.65; text-decoration: none; }
.digest-nav__link--accent { color: var(--accent); border-bottom-color: var(--accent); }
.digest-nav__link--muted  { color: var(--ink-muted); border-bottom-color: var(--ink-muted); }

/* ── Colophon ──────────────────────────────────────────── */
.colophon {
  padding: 0 0 48px;
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  text-align: center;
}

/* ── Back to top button ────────────────────────────────── */
.back-to-top {
  position: fixed;
  bottom: 32px;
  right: 32px;
  width: 44px;
  height: 44px;
  background: var(--ink);
  color: var(--paper);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 300;
  opacity: 0;
  pointer-events: none;
  transform: translateY(12px);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.back-to-top.visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.back-to-top:hover { background: var(--accent); }

/* ── Responsive ────────────────────────────────────────── */
@media (max-width: 640px) {
  .masthead {
    grid-template-columns: 1fr;
    text-align: center;
    padding: 32px 0 20px;
  }
  .masthead__left,
  .masthead__right { text-align: center; }
  .masthead__right { order: 3; }
  .tagline-bar { flex-direction: column; align-items: flex-start; gap: 4px; }
  .section-strip__name { display: none; }
  .back-to-top { bottom: 16px; right: 16px; }
}
</style>
