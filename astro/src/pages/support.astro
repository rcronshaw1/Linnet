---
import Base from '@/layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Support" description="Support the Linnet project">
  <div class="page-wrap" style="padding-top:2rem;padding-bottom:4rem;max-width:640px;">
    <div class="kicker">Support</div>
    <h1 style="font-size:clamp(1.8rem,3vw,2.6rem);font-weight:800;letter-spacing:-.03em;margin-bottom:.75rem;">
      Support Linnet
    </h1>
    <p style="color:var(--site-text-muted);font-size:1rem;line-height:1.8;margin-bottom:2rem;">
      Linnet is free, open-source, and maintained in spare time. If it saves you
      time every morning, consider supporting its development.
    </p>

    <div class="panel" style="padding:1.5rem;margin-bottom:1rem;">
      <div class="kicker">GitHub Sponsors</div>
      <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:.5rem;">Sponsor on GitHub</h2>
      <p style="color:var(--site-text-muted);font-size:.9rem;margin-bottom:1rem;">
        Monthly sponsorship through GitHub — directly supports development.
      </p>
      <a href="https://github.com/sponsors/YuyangXueEd" target="_blank" rel="noopener" class="btn btn--primary">
        GitHub Sponsors →
      </a>
    </div>

    <div class="panel" style="padding:1.5rem;">
      <div class="kicker">Ko-fi</div>
      <h2 style="font-size:1.1rem;font-weight:700;margin-bottom:.5rem;">Buy a coffee</h2>
      <p style="color:var(--site-text-muted);font-size:.9rem;margin-bottom:1rem;">
        One-time or recurring support via Ko-fi.
      </p>
      <a href="https://ko-fi.com/yuyangxue" target="_blank" rel="noopener" class="btn btn--secondary">
        Ko-fi →
      </a>
    </div>

    <div style="margin-top:1.5rem;text-align:center;">
      <a href={`${base}/`} style="color:var(--site-text-muted);font-size:.88rem;">← Back to home</a>
    </div>
  </div>
</Base>
